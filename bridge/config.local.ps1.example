# ============================================================
# UAIROX RFID Bridge — configuração local
# ------------------------------------------------------------
# COPIE este arquivo para "config.local.ps1" (no mesmo lugar)
# e preencha a sua chave. O config.local.ps1 NÃO vai para o git.
# ============================================================

# Chave do gateway (= RFID_GATEWAY_KEY do Supabase / campo "API Key" do painel)
$RFID_GATEWAY_KEY = "COLE_AQUI_SUA_CHAVE"

# Identificador deste leitor — TEM que ser igual ao cadastrado no painel de Antenas
$READER_ID = "reader-1"

# Rede do leitor M-ID40 LIGHT
$RFID_IP   = "192.168.0.10"
$RFID_PORT = "5000"

# Corte de RSSI (zona de leitura): ignora leituras fracas (atleta longe da antena).
# DEIXE COMENTADO para o bridge ler o campo "Sinal mínimo (RSSI)" da tela do evento.
# Descomente só para FORÇAR um valor fixo (ex: "70"). 0 = ler tudo.
# $RSSI_MIN  = "70"

# Anti-flood local (ms): só colapsa a rajada de leituras de uma passagem.
# NÃO é a regra dos 40s — essa é a "Zona Cega" do evento, aplicada pelo gateway
# só durante a prova. Padrão 3000 (3s). Normalmente não precisa mexer.
# $DEBOUNCE_MS = "3000"

# Verboso: "1" mostra TODA leitura crua (bom pra calibrar RSSI). Deixe "0" na prova.
$VERBOSE = "0"
